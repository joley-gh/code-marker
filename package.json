{
  "name": "code-marker",
  "displayName": "Code Marker",
  "description": "Highlight and manage code sections with ease by coloring them like a text book.",
  "version": "0.0.1",
  "publisher": "jonathan-leyes",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-marker.addHighlight",
        "title": "Add Highlight",
        "category": "Code Marker"
      },
      {
        "command": "code-marker.removeHighlight",
        "title": "Remove Highlight",
        "category": "Code Marker"
      },
      {
        "command": "code-marker.refreshHighlights",
        "title": "Refresh Highlights",
        "category": "Code Marker"
      },
      {
        "command": "code-marker.splitHighlight",
        "title": "Split Highlight",
        "category": "Code Marker"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "code-marker.addHighlight",
          "when": "editorHasSelection"
        },
        {
          "command": "code-marker.removeHighlight",
          "when": "editorHasSelection"
        },
        {
          "command": "code-marker.refreshHighlights",
          "when": "editorHasFocus"
        }
      ],
      "editor/context": [
        {
          "command": "code-marker.addHighlight",
          "when": "editorHasSelection && editorTextFocus",
          "group": "z_codeMarker@1"
        },
        {
          "command": "code-marker.removeHighlight",
          "when": "editorTextFocus",
          "group": "z_codeMarker@2"
        },
        {
          "command": "code-marker.refreshHighlights",
          "when": "editorTextFocus",
          "group": "z_codeMarker@3"
        },
        {
          "command": "code-marker.splitHighlight",
          "when": "editorTextFocus",
          "group": "z_codeMarker@4"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.0.0",
    "typescript": "^4.7.0"
  }
}
